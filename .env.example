# === LLM Provider (OpenAI-compatible) ===
# DeepSeek is the default — cheap, capable, OpenAI-compatible API.
# To use OpenAI directly, change baseURL to https://api.openai.com/v1
PROVIDER_BASE_URL=https://api.deepseek.com/v1
PROVIDER_API_KEY=your_deepseek_api_key_here
PROVIDER_MODEL=deepseek-chat

# === Google OAuth2 (Gmail API) ===
# 1. Create a Google Cloud project at https://console.cloud.google.com
# 2. Enable the Gmail API
# 3. Create an OAuth 2.0 Client ID (Desktop app type)
# 4. Fill in the client ID and secret below
# 5. Run: node setup-auth.js (follow the browser prompt)
# 6. The refresh token will be written back here automatically
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REFRESH_TOKEN=
